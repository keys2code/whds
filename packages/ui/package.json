{
  "name": "@keys2design/whds-ui",
  "version": "0.1.6",
  "description": "WHDS React UI components for buttons, badges, and switches.",
  "type": "module",
  "private": false,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keys2code/whds.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/keys2code/whds/tree/main/packages/ui",
  "bugs": {
    "url": "https://github.com/keys2code/whds/issues"
  },
  "scripts": {
    "build": "pnpm --dir ../tailwind-preset build && tsc -p tsconfig.build.json && node build.mjs",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "prepublishOnly": "pnpm run build && pnpm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "postcss.config.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@turbo/gen": "^2.8.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./dist/index.js",
    "./globals.css": "./dist/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./dist/lib/*.js",
    "./components/*": "./dist/components/*.js",
    "./hooks/*": "./dist/hooks/*.js"
  }
}
