{
  "name": "@workspace/design-registry",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @workspace/tokens build && pnpm --filter @workspace/tailwind-preset build && pnpm run registry:prepare && pnpm run build:registry && next dev --turbopack",
    "build": "pnpm --filter @workspace/tokens build && pnpm --filter @workspace/tailwind-preset build && pnpm run registry:prepare && pnpm run build:registry && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,json}\"",
    "typecheck": "tsc --noEmit",
    "registry:prepare": "node ./scripts/prepare-registry.mjs",
    "build:registry": "shadcn build registry.json --output public/r"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@workspace/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
